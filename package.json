  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n FRONTEND,BACKEND -c green,blue \"vite\" \"cd backend && node src/server.js\"",
    "dev:frontend": "vite",
    "dev:backend": "nodemon backend/src/server.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:push": "cd backend && npx drizzle-kit push",
    "db:seed": "node backend/src/db/seed.js"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.9",
    "vite-plugin-compression": "^0.5.1"
  }
